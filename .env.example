# TMDB API key (https://www.themoviedb.org/settings/api — free for personal use).
TMDB_API_KEY=

# Notion (https://www.notion.so/my-integrations).
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Auth.js — Google OAuth (https://console.cloud.google.com → OAuth client ID).
# AUTH_SECRET: generate with `openssl rand -base64 32`.
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Optional: restrict sign-in to a single Google Workspace domain (e.g. `yourcompany.com`).
# Leave empty to allow any Google account.
AUTH_ALLOWED_DOMAIN=
